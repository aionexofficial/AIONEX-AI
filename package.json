{
  "name": "aionex-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "remotion:studio": "remotion studio remotion/index.ts",
    "remotion:compositions": "remotion compositions remotion/index.ts",
    "remotion:render": "remotion render remotion/index.ts AionexIntro artifacts/remotion/aionex-intro.mp4",
    "pipeline:dry-run": "node --experimental-strip-types scripts/run-local-video-dry-run.ts",
    "automation:daily-video": "node --env-file-if-exists=.env.local scripts/run-daily-video-automation.mjs",
    "check:production-env": "node scripts/check-production-env.mjs",
    "db:migrate": "node --env-file-if-exists=.env.local scripts/migrate.mjs",
    "verify:rewards": "node scripts/verify-rewards.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@remotion/bundler": "4.0.490",
    "@remotion/cli": "4.0.490",
    "@remotion/renderer": "4.0.490",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-solflare": "^0.6.33",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.101.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.490",
    "viem": "^2.55.0",
    "wagmi": "^2.19.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "server-only": "^0.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
