NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_SITE_URL=https://aionex.ai
COINGECKO_API_KEY=optional_coingecko_pro_key
AUTH_SECRET=replace_with_a_long_random_secret
ADMIN_USERNAME=atlas
ADMIN_EMAIL=aionextoken@gmail.com
# Generate with: node scripts/hash-admin-password.mjs "your-password"
ADMIN_PASSWORD_HASH=salt:128_character_scrypt_hash
## Optional: the local AIONEX knowledge provider is used by default.
# AIONEX_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5

# Daily publishing (Neon Postgres from the Vercel Marketplace is recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
OPENAI_AUTOMATION_MODEL=gpt-5-mini
CRON_SECRET=replace_with_an_independent_long_random_secret
AUTO_PUBLISH=true
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token
TELEGRAM_CHANNEL_ID=@aionexweb3
TELEGRAM_BOT_USERNAME=AIONEXAIBot
TELEGRAM_WEBHOOK_SECRET=replace_with_a_random_webhook_secret

# AXP-only rewards configuration. Points have no token or monetary value.
REWARDS_MINING_AXP=100
REWARDS_LOGIN_AXP=20
REWARDS_REFERRER_AXP=100
REWARDS_REFERRED_AXP=50
# Recommended for unattended publishing: X OAuth 1.0a user context with Read/Write access.
X_CONSUMER_KEY=x_api_key
X_CONSUMER_SECRET=x_api_secret
X_ACCESS_TOKEN=x_access_token
X_ACCESS_TOKEN_SECRET=x_access_token_secret
# Optional alternative: OAuth 2.0 user-context token (must remain valid).
# X_USER_ACCESS_TOKEN=x_user_access_token
