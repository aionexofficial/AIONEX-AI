NEXT_PUBLIC_SITE_URL=https://aionex-ai.vercel.app
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
DATABASE_URL=
AUTH_SECRET=
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
CRON_SECRET=
AUTO_PUBLISH=false
TELEGRAM_BOT_TOKEN=
# Production content only. Must resolve to @aionexweb3.
TELEGRAM_CHANNEL_ID=@aionexweb3
# Private owner chat for errors, warnings, deployment status, logs, and debugging only.
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_AUTOMATION_MODEL=gpt-5-mini
# Production narration uses OpenAI TTS exclusively.
AIONEX_TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
# Local content generation (server-side only).
AIONEX_CONTENT_PROVIDER=ollama
AIONEX_AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=300000
COINGECKO_API_KEY=
REWARDS_MINING_AXP=100
REWARDS_LOGIN_AXP=20
REWARDS_REFERRER_AXP=100
REWARDS_REFERRED_AXP=50
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Required only when trusted X task verification is implemented through OAuth.
X_CLIENT_ID=
X_CLIENT_SECRET=
# Required only when trusted YouTube task verification is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Production uploads are always public; the runner rejects other visibility.
YOUTUBE_VISIBILITY=public
